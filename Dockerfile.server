FROM python:3.12-slim-bookworm@sha256:76d4b7b6305788c6b4c6a19d6a22a3921bf802e9af4d5e1e5bd771208dba74bf

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY server/requirements.lock /tmp/requirements.lock
RUN pip install --no-cache-dir --require-hashes -r /tmp/requirements.lock \
    && useradd --create-home --shell /usr/sbin/nologin mcp

COPY server ./server

# Non-root: the containerized server talks to the daemon via DOCKER_HOST
# (docker-socket-proxy), so no socket group membership is needed.
USER mcp

EXPOSE 8766

CMD ["python", "-m", "server.main", "--transport", "streamable-http", "--host", "0.0.0.0", "--port", "8766"]
