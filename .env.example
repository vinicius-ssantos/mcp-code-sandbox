# API key required by HTTP MCP clients.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Never commit the real value.
SANDBOX_API_KEY=

# MCP transport. Supported values: stdio, sse, streamable-http.
SANDBOX_TRANSPORT=stdio

# HTTP transport bind address. Defaults to localhost only.
SANDBOX_HOST=127.0.0.1

# HTTP transport port.
SANDBOX_PORT=8765

# Additional allowed HTTP Host headers for local containers or k3d.
SANDBOX_ALLOWED_HOSTS=host.docker.internal:8765,host.k3d.internal:8765

# Python logging level.
SANDBOX_LOG_LEVEL=INFO

# Max bytes returned per output stream (stdout/stderr). Default: 1 MiB.
SANDBOX_MAX_OUTPUT_BYTES=1048576

# Max number of files accepted by run_file. Default: 64.
SANDBOX_MAX_PROJECT_FILES=64

# Max total bytes accepted by run_file. Default: 8 MiB.
SANDBOX_MAX_PROJECT_BYTES=8388608

# Max number of environment variables accepted per execution. Default: 32.
SANDBOX_MAX_ENV_VARS=32

# Max number of output files that can be returned per execution. Default: 16.
SANDBOX_MAX_OUTPUT_FILES=16

# Max sandbox containers running at once. Default: 4.
SANDBOX_MAX_CONCURRENT=4

# Seconds a request waits for a free execution slot before failing. Default: 30.
SANDBOX_QUEUE_TIMEOUT_SECONDS=30

# Docker resource limits for sandbox containers.
# Do NOT raise these without updating the security rationale in ADR 0004.
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_PERIOD=100000
SANDBOX_CPU_QUOTA=50000
SANDBOX_PIDS_LIMIT=128
